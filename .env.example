# ============================================
# Market Research Aggregator - Environment Config
# ============================================
# Copy this file to .env and fill in your API keys.
# NEVER commit your .env file to version control.

# ----- Groq API (Writer Agent LLM) -----
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ----- Serper.dev API (Search Agent) -----
# Get your key at: https://serper.dev/api-key
SERPER_API_KEY=your_serper_api_key_here

# ----- Model Configuration -----
# Groq model to use for planning and writing
GROQ_MODEL=llama-3.3-70b-versatile

# Embedding model for RAG (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- Search Configuration -----
# Max search queries the planner generates per topic
MAX_SEARCH_QUERIES=8

# Max results per search query from Serper.dev
SEARCH_RESULTS_PER_QUERY=5

# Max articles to scrape and process
MAX_ARTICLES_TO_SCRAPE=15

# ----- RAG Configuration -----
# Chunk size in characters for text splitting
CHUNK_SIZE=1000

# Overlap between chunks in characters
CHUNK_OVERLAP=200

# Number of relevant chunks to retrieve for report writing
TOP_K_CHUNKS=20

# ----- Output Configuration -----
# Directory where final reports are saved
OUTPUT_DIR=./reports

# ----- MCP Server -----
MCP_SERVER_PORT=3001
